    "cross-spawn": "^7.0.3",
    "semver": "^7.6.3",
    "minimatch": "^3.1.2",
    "micromatch": "^4.0.8",
    "tar": "^6.2.1",
    "express": "^4.19.2",
    "tough-cookie": "^4.1.4",
