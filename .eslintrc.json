{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jquery": true,
    "mocha": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-undef": "warn",
    "semi": ["error", "always"],
    "quotes": ["warn", "single", { "allowTemplateLiterals": true }]
  },
  "globals": {
    "Web3": "readonly",
    "ethereum": "readonly",
    "window": "readonly",
    "$": "readonly",
    "jQuery": "readonly",
    "App": "writable",
    "require": "readonly",
    "module": "readonly",
    "process": "readonly",
    "artifacts": "readonly",
    "contract": "readonly",
    "assert": "readonly",
    "web3": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "build/",
    "public/app.bundle.js*",
    "Database_API/",
    "migrations/",
    "contracts/"
  ]
}
